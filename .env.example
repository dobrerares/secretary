# Telegram Bot
SECRETARY_TELEGRAM_BOT_TOKEN=your-telegram-bot-token
SECRETARY_TELEGRAM_USER_ID=123456789

# LLM Provider (LiteLLM model string)
# Examples: gpt-4o, claude-sonnet-4-20250514, ollama/llama3
SECRETARY_LLM_MODEL=gpt-4o
SECRETARY_LLM_API_KEY=your-llm-api-key

# Web UI auth token (generated on first run if empty)
SECRETARY_WEB_AUTH_TOKEN=

# Database (default: SQLite in data/ directory)
SECRETARY_DATABASE_URL=sqlite+aiosqlite:///data/secretary.db

# Whisper transcription: "local" (faster-whisper) or "cloud" (OpenAI API)
SECRETARY_WHISPER_MODE=local
SECRETARY_WHISPER_MODEL_SIZE=small
SECRETARY_OPENAI_API_KEY=

# Logging
SECRETARY_LOG_LEVEL=INFO

# Bot mode: "polling" (default, no public URL needed) or "webhook"
SECRETARY_BOT_MODE=polling
SECRETARY_WEBHOOK_URL=
